# Développement local (docker compose)

# Secret session (min. 32 caractères) — openssl rand -hex 32
SESSION_SECRET=dev-session-secret-change-me-32chars-min

# Compte admin initial (créé au premier démarrage si la base est vide)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production

CORS_ORIGINS=http://localhost:4321,http://localhost:8086
HTTP_PORT=8086

# Build web avec API relative (docker compose par défaut)
PUBLIC_API_BASE_URL=/api/v1

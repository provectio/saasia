# Copier vers .env sur la VM : cp .env.production.example .env

# Session signée (obligatoire) — openssl rand -hex 32
SESSION_SECRET=

# Compte admin (créé une seule fois si la base SQLite est vide)
ADMIN_USERNAME=
ADMIN_PASSWORD=

# Origines autorisées pour l'API (formulaire public)
CORS_ORIGINS=https://saas-readiness.provectio.fr

# Port hôte (debug / backend Traefik file provider). Avec labels Traefik, optionnel.
HTTP_PORT=8086

# Si docker-compose.traefik.yml — reprendre les valeurs de diag-infogerance
# TRAEFIK_NETWORK=traefik
# TRAEFIK_CERT_RESOLVER=letsencrypt

# L'URL API est compilée dans l'image web (/api/v1) — ne pas mettre PUBLIC_API_BASE_URL ici
